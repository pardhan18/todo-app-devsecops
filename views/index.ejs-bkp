<!DOCTYPE html>
<html>
<head>
    <title>Todo App</title>

    <style>
        body {
            font-family: Arial;
            margin: 40px;
        }

        input {
            padding: 10px;
        }

        button {
            padding: 10px;
        }

        li {
            margin: 10px 0;
        }
    </style>
</head>

<body>

    <h1>DevOps Todo Application</h1>

    <form action="/add" method="POST">
        <input type="text" name="task" placeholder="Enter Task" required>
        <button type="submit">Add</button>
    </form>

    <ul>
        <% todos.forEach(function(todo){ %>
            <li><%= todo %></li>
        <% }) %>
    </ul>

</body>
</html>
